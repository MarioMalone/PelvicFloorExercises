/* pages/settings/settings.wxss */
/* pages/settings/settings.wxss */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #E0E0E0;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #00F0FF;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.settings-group {
  padding: 0 30rpx !important;
}

.setting-item {
  padding: 30rpx 0;
  border-bottom: 1px solid rgba(0, 240, 255, 0.1);
}

.border-none {
  border-bottom: none;
}

.item-label {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.item-label .title {
  font-size: 30rpx;
  font-weight: 500;
  color: #E0E0E0;
  letter-spacing: 1rpx;
}

.item-label .desc {
  font-size: 22rpx;
  color: #808090;
  margin-top: 6rpx;
}

.item-control {
  display: flex;
  align-items: center;
}

slider {
  flex: 1;
  margin: 0 20rpx 0 0;
}

.unit {
  font-size: 26rpx;
  color: #A0A0B0;
  min-width: 40rpx;
}

.picker-value {
  font-size: 32rpx;
  color: #00F0FF;
  font-weight: 500;
  margin-right: 10rpx;
  text-shadow: 0 0 10rpx rgba(0, 240, 255, 0.4);
}

.margin-top {
  margin-top: 60rpx;
}

.danger-zone {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.danger-text {
  color: #FF3366;
  font-size: 28rpx;
  text-shadow: 0 0 8rpx rgba(255, 51, 102, 0.4);
  letter-spacing: 1rpx;
}

.danger-arrow {
  color: #808090;
}

.footer {
  text-align: center;
  margin-top: 100rpx;
  padding-bottom: 40rpx;
}

.footer text {
  font-size: 24rpx;
  color: #606070;
  letter-spacing: 2rpx;
}
