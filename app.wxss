/**app.wxss**/
page {
  background-color: #050505;
  font-family: 'Helvetica Neue', 'Inter', -apple-system, sans-serif;
  color: #E0E0E0;
  font-size: 28rpx;
  line-height: 1.4;
  /* 微弱放射光晕背景，模拟屏幕底层纹理 */
  background-image: radial-gradient(circle at 50% 50%, rgba(0, 240, 255, 0.03) 0%, transparent 80%);
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 30rpx;
} 

/* 通用按钮样式 - 科幻主题 */
.btn-primary {
  background: linear-gradient(135deg, rgba(0, 240, 255, 0.2) 0%, rgba(0, 240, 255, 0.05) 100%);
  color: #00F0FF;
  border: 1px solid rgba(0, 240, 255, 0.5);
  border-radius: 12rpx; /* 更锐利的边角 */
  padding: 20rpx 60rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  text-align: center;
  box-shadow: 0 0 15rpx rgba(0, 240, 255, 0.2), inset 0 0 10rpx rgba(0, 240, 255, 0.1);
  text-transform: uppercase;
  transition: all 0.3s ease;
}

.btn-primary:active {
  background: rgba(0, 240, 255, 0.3);
  box-shadow: 0 0 25rpx rgba(0, 240, 255, 0.5), inset 0 0 15rpx rgba(0, 240, 255, 0.2);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: #A0A0B0;
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx 60rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

/* 优雅卡片样式 - 科幻HUD面板 */
.card {
  background: rgba(15, 20, 30, 0.7); /* 深蓝色半透明背景 */
  border: 1px solid rgba(0, 240, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5), inset 0 0 20rpx rgba(0, 240, 255, 0.02);
  backdrop-filter: blur(10px); /* 玻璃毛玻璃效果 */
  position: relative;
  overflow: hidden;
}

/* 卡片科技感边角点缀 */
.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 15rpx;
  height: 15rpx;
  border-top: 2px solid #00F0FF;
  border-left: 2px solid #00F0FF;
  opacity: 0.7;
}

.card::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 15rpx;
  height: 15rpx;
  border-bottom: 2px solid #00F0FF;
  border-right: 2px solid #00F0FF;
  opacity: 0.7;
}
